# ============================================
# CONFIGURATION - Intelligence Opérationnelle
# ============================================
# Copie ce fichier vers .env.local et remplis les valeurs
# Commande: copy env.example .env.local

# SUPABASE - Base de données
# Trouve ces valeurs dans : https://supabase.com/dashboard → Ton projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ta-cle-anon-ici

# OPTIONNEL - Pour les fonctions serveur (plus tard)
# SUPABASE_SERVICE_ROLE_KEY=ta-cle-service-ici

# OPTIONNEL - Clés API IA (à configurer plus tard)
# OPENAI_API_KEY=sk-...
