# ============================================
# CONFIGURATION - Intelligence Opérationnelle
# ============================================
# Copie ce fichier vers .env.local et remplis les valeurs
# Commande: copy env.example .env.local

# SUPABASE - Base de données
# Trouve ces valeurs dans : https://supabase.com/dashboard → Ton projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ta-cle-anon-ici

# OPTIONNEL - Pour les fonctions serveur (plus tard)
# SUPABASE_SERVICE_ROLE_KEY=ta-cle-service-ici

# OPTIONNEL - Clés API IA (à configurer plus tard)
# OPENAI_API_KEY=sk-...

# GOOGLE PLACES API - Pour le Radar de Prospection
# Obtenir une clé: https://console.cloud.google.com/apis/credentials
# Activer: Places API (New) dans la console Google Cloud
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# TRACKDÉCHETS API - Pour les Bordereaux de Suivi des Déchets (BSD)
# Obtenir une clé: https://developers.trackdechets.beta.gouv.fr/
# Mode PRODUCTION (clé réelle)
TRACKDECHETS_API_KEY=your_trackdechets_production_api_key_here
# Mode SANDBOX (pour tests)
TRACKDECHETS_SANDBOX_API_KEY=your_trackdechets_sandbox_api_key_here

# ============================================
# SEO & INDEXATION GOOGLE
# ============================================
# URL publique du site (utilisée pour sitemap et canonical)
NEXT_PUBLIC_SITE_URL=https://capital-energie.fr

# Google Search Console - Code de vérification
# Obtenir: https://search.google.com/search-console → Ajouter propriété → Balise HTML
# Copier uniquement le contenu de l'attribut "content"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_code_here
